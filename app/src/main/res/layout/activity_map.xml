<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#081B1B">

    <!-- TOP BAR -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:padding="10dp"
        android:background="#0F2A2A">

        <Spinner
            android:id="@+id/spinnerMapAI"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:background="#203837"
            android:popupBackground="#E9C46A"
            android:padding="8dp"
            android:spinnerMode="dropdown"/>

        <Button
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:text="⬅"
            android:textColor="#081B1B"
            android:backgroundTint="#E9C46A"
            android:layout_marginStart="10dp"/>
    </LinearLayout>

    <!-- MAP -->
    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/map"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <!-- 🔥 Bottom Navigation FIXED -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#EEE8B2"

        app:menu="@menu/bottom_menu"

        app:itemIconTint="#5A8F76"
        app:itemTextColor="#5A8F76"
        app:itemActiveIndicatorStyle="@null"/>
</LinearLayout>